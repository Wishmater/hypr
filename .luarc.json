{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "workspace.library": [
    "hl.meta.lua"
  ],
  "runtime.version": "Lua 5.5",
  "runtime.path": [
    "?.lua",
    "?/init.lua"
  ],
  "diagnostics.globals": [
    "hl"
  ],
  "format.enable": false,
    "diagnostics.disable": [
        "lowercase-global"
    ]
}
